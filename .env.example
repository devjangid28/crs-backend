# ============================================================
# CRS Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Render deployment, set ALL variables below via the
# Render Dashboard (Environment Variables) — NOT in this file.

# ---------- Render PostgreSQL (Production) ----------
# Set this in Render Dashboard using the Internal Database URL
# from your Render PostgreSQL instance.
DATABASE_URL=your_database_url_here

# ---------- Local PostgreSQL (Development) ----------
# Uncomment for local testing with a local PostgreSQL instance:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_NAME=repair_management_system

# ---------- JWT Authentication ----------
# Generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Set this in Render Dashboard for production.
JWT_SECRET=your_jwt_secret_here

# ---------- CORS ----------
# In production, replace * with your frontend domain:
#   https://your-app.onrender.com
CORS_ORIGIN=*

# ---------- Server ----------
PORT=5000
NODE_ENV=production

# ---------- Uploads ----------
UPLOAD_DIR=./uploads

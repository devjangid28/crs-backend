# ============================================================
# CRS Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Render PostgreSQL (Production - set in Render dashboard)
# DATABASE_URL=postgresql://user:password@host:5432/repair_management_system

# PostgreSQL Database (Local Development - uncomment for local testing)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_NAME=repair_management_system

# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Secret (for future auth implementation)
JWT_SECRET=your-secret-key-here-change-in-production

# CORS Origin
CORS_ORIGIN=http://localhost:5173

# Upload Directory
UPLOAD_DIR=./uploads
